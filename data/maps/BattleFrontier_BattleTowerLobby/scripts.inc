	.string "You don't have three eligible POKéMON.\p"
	.string "You need three different POKéMON\n"
	.string "at Level 50 or lower to enter.\p"
	.string "They also gotta be holding different\n"
	.string "items.\p"
	.string "EGGS{STR_VAR_1}.$"

